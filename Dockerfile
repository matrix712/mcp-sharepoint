FROM node:22-bookworm-slim

# Prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install required system packages
RUN apt-get update && apt-get install -y \
    git \
    python3 \
    make \
    g++ \
    libcairo2 \
    libcairo2-dev \
    libpango-1.0-0 \
    libpango1.0-dev \
    libjpeg62-turbo \
    libjpeg62-turbo-dev \
    libgif7 \
    libgif-dev \
    librsvg2-2 \
    librsvg2-dev \
    pkg-config \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone latest project
RUN git clone https://github.com/memori-ai/mcp-sharepoint.git .

# Remove lock file to avoid incompatible dependency resolution
RUN rm -f package-lock.json

# Install dependencies
RUN npm install

# Downgrade pdf-parse to a stable version
RUN npm install pdf-parse@2.3.12 --save-exact

# Clean npm cache
RUN npm cache clean --force

# Install mcp-proxy — bridges stdio to SSE/HTTP, spawns a fresh child
# process per session (fixes the "Already connected" crash supergateway had)
RUN npm install -g mcp-proxy

# Write the credential-injecting wrapper directly into the image (base64
# encoded to avoid Dockerfile quoting issues). It hides tenantId/clientId/
# clientSecret/siteId/driveId from the tool schema Claude sees, and injects
# the real values (from env vars set in Easypanel) on every tool call.
RUN echo  | base64 -d > /app/wrapper.cjs

EXPOSE 8000

# mcp-proxy launches the wrapper instead of src/index.js directly.
# The wrapper spawns src/index.js itself and proxies stdio to/from it.
CMD ["mcp-proxy", "--port", "8000", "--sseEndpoint", "/sse", "--", "node", "wrapper.cjs"]
